{
  "name": "json-server-docker",
  "version": "0.0.0-semantically-released",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "license": "MIT",
  "scripts": {
    "start": "nodemon server.js",
    "build": "rm -rf dist && tsc",
    "typecheck": "tsc --noEmit",
    "format": "eslint --fix",
    "lint": "eslint"
  },
  "dependencies": {
    "@faker-js/faker": "^10.3.0",
    "@types/node": "^24.0.0",
    "chalk": "^5.2.0",
    "json-server": "1.0.0-beta.12",
    "lodash-es": "^4.17.21",
    "lowdb": "^7.0.0",
    "nodemon": "^3.1.0",
    "typescript": "^5.8.0",
    "zx": "^8.8.5"
  },
  "devDependencies": {
    "@codfish/eslint-config": "^13.1.2",
    "eslint": "^10.0.3"
  },
  "nodemonConfig": {
    "ignore": [
      "dist/",
      "package.json",
      "pnpm-lock.yaml"
    ],
    "ext": "js,mjs,ts,json"
  }
}
